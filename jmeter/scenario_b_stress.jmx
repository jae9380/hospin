<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Hospin Stress Test - Scenario B-1/B-2">
      <stringProp name="TestPlan.comments">시나리오 B-1: 단계별 스트레스 (Knee Point 탐지)
  10 → 30 → 50 → 70 → 100 Users 순차 실행 (각 300s)
  혼합 부하: hospital_search 40% / hospital_nearby 30% / hospital_detail 15% / schedule CRUD 10%

시나리오 B-2: 레이어별 병목 분석
  50 Users, 600s 단독 실행 — Grafana Layer 섹션 관찰용

실행: serialize=true (모든 ThreadGroup 순차 실행)
CLI: jmeter -n -t scenario_b_stress.jmx -JTS=$(date +%Y%m%d-%H%M%S) -l /dev/null
결과: /Users/jae/results/b_{TS}/b1_10u_{TS}.jtl ... b2_50u_{TS}.jtl</stringProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
    </TestPlan>
    <hashTree>
      <SetupThreadGroup guiclass="SetupThreadGroupGui" testclass="SetupThreadGroup" testname="setUp Thread Group">
        <stringProp name="TestPlan.comments">TS 타임스탬프 초기화. CLI 미전달 시 현재 시각으로 자동 설정</stringProp>
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </SetupThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="TS 초기화 (타임스탬프)" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">if (!props.get(&quot;TS&quot;) || props.get(&quot;TS&quot;) == &quot;1&quot;) {
    props.put(&quot;TS&quot;, new Date().format(&quot;yyyyMMdd-HHmmss&quot;))
}
log.info(&quot;TS = &quot; + props.get(&quot;TS&quot;))</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
